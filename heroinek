            container.ZIndex = 100
        else
            container.ZIndex = 5
        end
    end)

    mainBtn.Text = "  " .. currentValue
    task.spawn(function() callback(currentValue) end)

    return {
        SetValue = function(val)
            mainBtn.Text = "  " .. val
            ConfigSystem.Settings[id] = val
            SaveConfig()
            callback(val)
        end
    }
end

