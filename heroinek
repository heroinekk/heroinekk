MiscSection:Toggle("AnywhereDrag", {
    Title = "Move GUI Anywhere",
    Description = "Drag the GUI by clicking anywhere on it (not just the top bar).",
    Default = true,
    Callback = function(Value)
        _G.AnywhereDrag = Value
        local frame = Window.Instance
        local dragInput, dragStart, startPos
        
        if _G.DragCon1 then _G.DragCon1:Disconnect() end
        if _G.DragCon2 then _G.DragCon2:Disconnect() end
        
        _G.DragCon1 = UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and _G.AnywhereDrag then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        
        _G.DragCon2 = frame.InputBegan:Connect(function(input)
            if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and _G.AnywhereDrag then
                dragStart = input.Position
                startPos = frame.Position
                
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragInput = nil
                    end
                end)
                dragInput = input
            end
        end)
    end
})

