-- SYSTEM KONFIGURACJI (AUTO-SAVE / AUTO-LOAD)
-- =========================================
local ConfigSystem = {
    Folder = "AnniversaryHub",
    File = "AnniversaryHub/Config.json",
    Settings = {}
}

local function SaveConfig()
    if writefile then
        pcall(function()
            if not isfolder(ConfigSystem.Folder) then
                makefolder(ConfigSystem.Folder)
            end
            writefile(ConfigSystem.File, HttpService:JSONEncode(ConfigSystem.Settings))
        end)
    end
end

local function LoadConfig()
    if readfile and isfile and isfile(ConfigSystem.File) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(ConfigSystem.File))
            if type(decoded) == "table" then
                for k, v in pairs(decoded) do
                    ConfigSystem.Settings[k] = v
                end
            end
        end)
    end
end

LoadConfig() -- Ładowanie konfiguracji przy starcie

