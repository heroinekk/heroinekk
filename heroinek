    Title = "Quest Status",
    Content = "Waiting to start...",
    TitleAlignment = "Middle"
})
local autoRoksekEnabled = false

local function ParseSuffixedNumber(str)
    if not str then return 0 end
    str = string.gsub(str, ",", ""):upper()
    local num = tonumber(string.match(str, "%d+%.?%d*")) or 0
    if string.find(str, "K") then num = num * 1000
    elseif string.find(str, "M") then num = num * 1000000
    elseif string.find(str, "B") then num = num * 1000000000 end
    return num
end

QuestAutoSection:Toggle("AnnivAutoRoksek", {
    Title = "START ROKSEK QUESTS (SMART)",
    Default = false,
    Callback = function(Value)
        autoRoksekEnabled = Value
        if Value then
            task.spawn(function()
                local Knit = require(ReplicatedStorage.Packages.Knit)
                local lastClickedTab, checkTimer = nil, tick()
                
                while autoRoksekEnabled do
                    pcall(function()
                        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                        local roksekFrame = playerGui and playerGui.MainUI.Menus:FindFirstChild("AnniversaryRoksekNPCFrame")
                        if not roksekFrame then RoksekStatus:SetValue("Waiting for NPC Window..."); return end

                        local displaysList = roksekFrame.Displays.List
                        local hourlyTab, dailyTab = displaysList.Hourly, displaysList.Daily
                        local mainHolder = roksekFrame.Main.Holder

                        local function clickTab(tab)
                            if not tab or lastClickedTab == tab then return end
                            if getconnections then
                                local click = tab:FindFirstChild("Click") or tab
                                for _, conn in ipairs(getconnections(click.MouseButton1Click)) do pcall(function() conn:Fire() end) end
                            end
                            lastClickedTab = tab
                            task.wait(0.8)
                        end

                        local statusLines, activeQuestFound = {}, false

                        local function ScanQuests(prefix)
                            local allLocked = true
                            if not mainHolder then return true end
                            for i = 1, 4 do
                                local slot = mainHolder:FindFirstChild(tostring(i))
                                if slot and slot:FindFirstChild("Main") then
                                    local lockedFrame = slot.Main:FindFirstChild("Locked")
                                    local isLocked = false
                                    if lockedFrame and lockedFrame.Visible then
                                        if lockedFrame:IsA("GuiObject") and lockedFrame.BackgroundTransparency < 0.95 then isLocked = true end
                                        local lockIcon = lockedFrame:FindFirstChild("_lockIcon")
                                        if lockIcon and lockIcon.Visible and (not lockIcon:IsA("ImageLabel") or lockIcon.ImageTransparency < 0.95) then isLocked = true end
                                        for _, child in ipairs(lockedFrame:GetDescendants()) do
                                            if child:IsA("TextLabel") and child.Visible and child.TextTransparency < 0.95 then
                                                local txt = string.lower(child.Text)
                                                if string.match(txt, "%d+m %d+s") or string.match(txt, "%d+h %d+m") or string.match(txt, "%d+s") then isLocked = true; break end
                                            end
                                        end
                                    end
                                    
                                    if isLocked then 
                                        table.insert(statusLines, string.format("[%s] Slot %d: Locked 🔒", prefix, i))
                                        continue 
                                    end

                                    local questName = slot.Main:FindFirstChild("UpgradeName") and slot.Main.UpgradeName.Text or "Unknown quest"
                                    local progressFrame = slot.Main:FindFirstChild("Progress")
                                    local progressText = ""
                                    if progressFrame then
                                        for _, d in ipairs(progressFrame:GetDescendants()) do if d:IsA("TextLabel") and string.find(d.Text, "/") then progressText = d.Text; break end end
                                        if progressText == "" then
                                            local txtLbl = progressFrame:FindFirstChildOfClass("TextLabel") or progressFrame:FindFirstChild("Amount") or progressFrame:FindFirstChild("Text")
                                            if txtLbl then progressText = txtLbl.Text end
                                        end
                                    end

                                    local isCompleted = false
                                    if string.find(string.lower(progressText), "max") or string.find(string.lower(progressText), "done") then isCompleted = true
                                    else
                                        local curStr, maxStr = string.match(progressText, "([%d%.,KMBkmb]+)%s*/%s*([%d%.,KMBkmb]+)")
                                        if curStr and maxStr then
                                            if ParseSuffixedNumber(curStr) >= ParseSuffixedNumber(maxStr) then isCompleted = true end
                                        end
                                    end

                                    if isCompleted then 
                                        table.insert(statusLines, string.format("[%s] Slot %d: Finished ⏳", prefix, i))
                                    else
                                        allLocked = false
                                        if not activeQuestFound then
                                            activeQuestFound = true
                                            table.insert(statusLines, string.format("[%s] Slot %d: %s [%s] (DOING 🚀)", prefix, i, questName, progressText))
                                            
                                            local lowerName = questName:lower()
                                            if string.find(lowerName, "hatch") or string.find(lowerName, "egg") then
                                                local targetEgg = selectedQuestEggName
                                                for _, egg in ipairs(eggOptions) do if string.find(lowerName, egg:lower()) then targetEgg = egg; break end end
                                                Knit.GetService("EggService").openEgg._re:FireServer(targetEgg, selectedHatchAmount)
                                                
                                            elseif string.find(lowerName, "boss") or string.find(lowerName, "defeat") then
                                                local targetId = 1
                                                for _, b in ipairs(bossDataList) do if string.find(lowerName, b.name:lower()) then targetId = tonumber(b.id); break end end
                                                local BossSrv = Knit.GetService("AnniversaryBossService")
                                                local hud = playerGui.MainUI.HUD.Bars:FindFirstChild("BossFightHUD_Boss")
                                                
                                                -- TELEPORT BYPASS
                                                if hud and hud.Visible then 
                                                    BossSrv.damage._re:FireServer() 
                                                else 
                                                    BossSrv:startFight(targetId) 
                                                end
                                                
                                            elseif string.find(lowerName, "use") and string.find(lowerName, "ticket") then
                                                local data = Knit.GetController("DataController"):getData()
                                                if data and data.inventory then
                                                    for _, items in pairs(data.inventory) do
                                                        for id, it in pairs(items) do
                                                            if (type(it) == "table" and it.nm and string.find(it.nm:lower(), "anniversaryticket")) or (type(id) == "string" and string.find(id:lower(), "anniversaryticket")) then
                                                                Knit.GetService("InventoryService"):useItem(id, {use = 1}); break
                                                            end
                                                        end
                                                    end
                                                end
                                            elseif string.find(lowerName, "rebirth") then
                                                local AnniversaryService = Knit.GetService("AnniversaryService")
                                                if AnniversaryService and AnniversaryService.anniversaryRebirth then AnniversaryService:anniversaryRebirth() end
                                            end
                                        else
                                            table.insert(statusLines, string.format("[%s] Slot %d: Queued ⏸️", prefix, i))
                                        end
                                    end
                                end
                            end
                            return allLocked
                        end

                        if selectedRoksekMode == "Hourly & Daily" then
                            clickTab(hourlyTab)
                            if ScanQuests("Hourly") then
                                statusLines = {}
                                clickTab(dailyTab)
                                ScanQuests("Daily")
                                if tick() - checkTimer > 40 then lastClickedTab = nil; checkTimer = tick() end
                            else checkTimer = tick() end
                        elseif selectedRoksekMode == "Only Hourly" then clickTab(hourlyTab); ScanQuests("Hourly")
                        elseif selectedRoksekMode == "Only Daily" then clickTab(dailyTab); ScanQuests("Daily") end

                        RoksekStatus:SetValue(table.concat(statusLines, "\n"))
                    end)
                    task.wait(0.2)
                end
            end)
        else 
            RoksekStatus:SetValue("Waiting to start...")
        end
    end
})

