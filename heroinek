-- [EVENTS SECTION - TU JEST TWOJE KOŁO]
local RngSection = Tabs.Events:AddSection("RNG & Minigames")

local autoRngEnabled = false
RngSection:Toggle("AnnivAutoRng", {
    Title = "Auto Hatch RNG Egg",
    Default = false,
    Callback = function(Value)
        autoRngEnabled = Value
        if Value then
            task.spawn(function()
                local Knit = require(ReplicatedStorage.Packages.Knit)
                while autoRngEnabled do
                    pcall(function()
                        local EggCtrl = Knit.GetController("EggController")
                        if EggCtrl.globalEggId then
                            local EggSrv = Knit.GetService("EggService")
                            EggSrv.setIsAutoHatching._re:FireServer(EggCtrl.globalEggId)
                            EggSrv.openEgg._re:FireServer(EggCtrl.globalEggId, 99, {isRNGEgg=true})
                        end
                    end)
                    task.wait(0.5)
                end
            end)
        end
    end
})

RngSection:Toggle("AnnivAutoWheel", {
    Title = "Auto Devs Wheel Spin (Wait for Cooldown)",
    Description = "Automatically spins the wheel as soon as the server allows it.",
    Default = false,
    Callback = function(Value)
        _G.AutoWheel = Value
        if Value then
            task.spawn(function()
                local Knit = require(ReplicatedStorage.Packages.Knit)
                while _G.AutoWheel do
                    pcall(function() Knit.GetService("AnniversaryService"):devsWheelSpin() end)
                    task.wait(10) -- Sprawdza co 10 sekund czy cooldown minął
                end
            end)
        end
    end
})

