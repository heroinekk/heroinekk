        local visibleCount = 0
        for _, opt in ipairs(optionBtns) do
            local visible = searchText == "" or string.find(opt.name, searchText, 1, true)
            opt.btn.Visible = visible
            if visible then visibleCount = visibleCount + 1 end
        end
        listFrame.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 24)
