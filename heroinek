-- [FARMING SECTION]
local BossSection = Tabs.Farming:AddSection("Boss Farming")
local selectedBossId = 1
BossSection:Dropdown("AnnivBossDropdown", {
    Title = "Select Boss",
    Values = bossNames or {"1. Haunted Miner"},
    Default = 1,
    Callback = function(Value)
        local id = Value:match("^(%d+)")
        if id then selectedBossId = tonumber(id) end
    end
})

local autoBossEnabled = false
BossSection:Toggle("AnnivAutoBoss", {
    Title = "Auto Boss (Remote)",
    Default = false,
    Callback = function(Value)
        autoBossEnabled = Value
        if Value then
            task.spawn(function()
                local Knit = require(ReplicatedStorage.Packages.Knit)
                while autoBossEnabled do
                    pcall(function()
                        local BossSrv = Knit.GetService("AnniversaryBossService")
                        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
                        local bossHUD = pGui and pGui.MainUI.HUD.Bars:FindFirstChild("BossFightHUD_Boss")
                        
                        if bossHUD and bossHUD.Visible then
                            for i = 1, 5 do BossSrv.damage._re:FireServer() end
                        else
                            BossSrv:startFight(selectedBossId)
                            task.wait(0.5)
                        end
                    end)
                    task.wait(0.1)
                end
            end)
        end
    end
})

Tabs.Farming:AddToggle("AnnivAutoRebirth", {
    Title = "Auto Anniversary Rebirth",
    Default = false,
    Callback = function(Value)
        _G.AnnivRebirth = Value
        if Value then
            task.spawn(function()
                local Knit = require(ReplicatedStorage.Packages.Knit)
                while _G.AnnivRebirth do
                    pcall(function() Knit.GetService("AnniversaryService"):anniversaryRebirth() end)
                    task.wait(3)
                end
            end)
        end
    end
})

-- [SHOP SECTION]
local ShopItemsSection = Tabs.Shop:AddSection("Buy Items")
local selectedShopItemIds = {}
ShopItemsSection:Dropdown("AnnivShopItems", {
    Title = "Select Items to Buy",
    Values = shopOptions,
    Multi = true,
    Default = {},
    Callback = function(Value)
        selectedShopItemIds = {}
        for name, isSelected in pairs(Value) do
            if isSelected and shopItemMap[name] then selectedShopItemIds[shopItemMap[name]] = true end
        end
    end
})

ShopItemsSection:Toggle("AnnivAutoShop", {
    Title = "Auto Buy Selected Items",
    Default = false,
    Callback = function(Value)
        _G.AnnivShop = Value
        if Value then
            task.spawn(function()
                local Knit = require(ReplicatedStorage.Packages.Knit)
                while _G.AnnivShop do
                    local AnnivSrv = Knit.GetService("AnniversaryService")
                    for itemId, _ in pairs(selectedShopItemIds) do 
                        pcall(function() AnnivSrv:buyAnniversaryShop(itemId) end) 
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})

