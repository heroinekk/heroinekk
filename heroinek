    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = frame
    
    local statusIndicator = Instance.new("Frame")
    statusIndicator.Size = UDim2.new(0, 40, 0, 20)
    statusIndicator.Position = UDim2.new(1, -50, 0.5, -10)
    statusIndicator.Parent = frame
    Instance.new("UICorner", statusIndicator).CornerRadius = UDim.new(1, 0)
    
    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 14, 0, 14)
    dot.Parent = statusIndicator
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    
    local state = ConfigSystem.Settings[id] or false

    local function ApplyVisuals(instant)
        local targetX = state and 23 or 3
        local targetColor = state and Color3.fromRGB(40, 180, 40) or Color3.fromRGB(50, 50, 60)
        local dotColor = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
        
        btn.Text = state and ("  [ ON ] " .. text) or ("  [ OFF ] " .. text)
        btn.TextColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(220, 220, 225)
        
        if instant then
            dot.Position = UDim2.new(0, targetX, 0.5, -7)
            dot.BackgroundColor3 = dotColor
            statusIndicator.BackgroundColor3 = targetColor
        else
            TweenService:Create(dot, TweenInfo.new(0.2), {Position = UDim2.new(0, targetX, 0.5, -7), BackgroundColor3 = dotColor}):Play()
            TweenService:Create(statusIndicator, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        end
    end

    btn.MouseButton1Click:Connect(function()
        state = not state
        ConfigSystem.Settings[id] = state
        SaveConfig()
        ApplyVisuals(false)
        callback(state)
    end)
    
    ApplyVisuals(true)
    task.spawn(function() callback(state) end)
    
    return frame
end

