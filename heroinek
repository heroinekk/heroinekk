-- Pobieranie Jajek
local eggOptions, displayToEggName = {}, {}
pcall(function()
    local EggsModule = require(ReplicatedStorage.Shared.List.Pets.Eggs)
    if EggsModule then
        for eggName, eggData in pairs(EggsModule) do
            if typeof(eggData) == "table" and not eggName:lower():find("exclusive") then
                table.insert(eggOptions, eggName)
                displayToEggName[eggName] = eggName
            end
        end
    end
end)
if #eggOptions == 0 then
    local fallbackEggs = {"Basic", "Rare", "Epic", "Heaven"}
    for _, item in ipairs(fallbackEggs) do table.insert(eggOptions, item); displayToEggName[item] = item end
end
table.sort(eggOptions)

-- Pobieranie Bossów
local bossDataList = {}
pcall(function()
    local AnniversaryBosses = require(ReplicatedStorage.Shared.List.Anniversary.AnniversaryBosses)
    if AnniversaryBosses then
        for id, bossData in pairs(AnniversaryBosses) do table.insert(bossDataList, {id = tostring(id), name = bossData.name}) end
        table.sort(bossDataList, function(a, b) return tonumber(a.id) < tonumber(b.id) end)
    end
end)
if #bossDataList == 0 then
    bossDataList = {
        {id = "1", name = "Haunted Miner"}, {id = "2", name = "Spider"}, {id = "3", name = "Evil Panda"},
        {id = "4", name = "Kraken"}, {id = "5", name = "Circus Monster"}
    }
end
local bossNames, bossMap = {}, {}
for _, boss in ipairs(bossDataList) do
    local displayName = boss.id .. ". " .. boss.name
    table.insert(bossNames, displayName)
    bossMap[displayName] = boss.id
end

-- Pobieranie Sklepu
local shopOptions, shopItemMap = {}, {}
pcall(function()
    local AnniversaryShopList = require(ReplicatedStorage.Shared.List.Anniversary.AnniversaryShop)
    if AnniversaryShopList then
        for id, data in pairs(AnniversaryShopList) do
            local dName = data.name or id
            table.insert(shopOptions, dName)
            shopItemMap[dName] = id
        end
    end
end)
if #shopOptions == 0 then
    local fallbackItems = {"exclusiveEgg", "damagePotion", "luckPotion", "coinPotion"}
    for _, item in ipairs(fallbackItems) do table.insert(shopOptions, item); shopItemMap[item] = item end
end
table.sort(shopOptions)

